  "byok_detection_strategy": {
    "method": "suffix_and_naming_convention",
    "rules": [
      "Model UID contains '-byok' suffix → BYOK model",
      "Model UID contains '-byok-beta' suffix → BYOK model",
      "Model UID ends with '-YYYYMMDD' (8 digits) → Pro subscription model",
      "Model UID without suffix and not in free list → BYOK model",
      "Known BYOK models: gpt-5-*, claude-opus-4-*, gemini-3-*",
      "Error 'unknown model UID: model not found' → BYOK not configured"
    ],
    "implementation": "function detectModelTier(modelUid) { if (modelUid.includes('-byok')) return 'byok'; if (/\\d{8}$/.test(modelUid)) return 'pro'; if (['kimi-k2-6', 'kimi-k2-6-e', 'glm-5', 'glm-5-1'].includes(modelUid)) return 'free'; return 'byok'; }"
  },
