# ============================================================================
# Keep these files
# ============================================================================

# Force include important files even if they match patterns above
!.gitignore
!.gitkeep
!README.md
!requirements.txt
!CHANGELOG.md
!CONTRIBUTING.md
!LICENSE

# ============================================================================
# Notes
# ============================================================================

# This .gitignore is specifically designed for the Windsurf Authentication
# Toolkit. It protects sensitive token files and credentials from being
# accidentally committed to version control.
#
# CRITICAL: Never commit tokens.json or any file containing sessionId or
# csrfToken values. These are security-sensitive and should remain local.
#
# If you need to share example token files, use placeholder values:
# {
#   "sessionId": "example-session-id-abc123",
#   "csrfToken": "example-csrf-token-xyz789"
# }
